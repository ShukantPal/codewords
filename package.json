{
  "name": "codewords",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "worker:dev": "wrangler dev",
    "worker:deploy": "wrangler deploy",
    "worker:dry-run": "wrangler deploy --dry-run --outdir /tmp/codewords-worker",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.node.json --noEmit",
    "test": "npm run test:unit",
    "test:unit": "tsx --test tests/*.test.ts",
    "test:integration": "npm run build && tsx --test tests/integration/**/*.test.ts",
    "simulate": "tsx scripts/simulate-http-game.ts",
    "simulate:demo": "tsx scripts/simulate-http-game.ts --base-url http://localhost:8787 --game-id main --strategy random --delay-ms 1200 --max-turns 40",
    "reset:demo": "node -e \"fetch('http://localhost:8787/api/games/main/reset',{method:'POST'}).then(r=>{console.log(r.status); if(!r.ok) process.exit(1)})\"",
    "check": "npm run typecheck && npm run test:unit && npm run test:integration && npm run worker:dry-run",
    "preview": "vite preview"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260525.0",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "tsx": "^4.22.3",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "wrangler": "^4.94.0"
  }
}
